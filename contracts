#![no_std]

use soroban_sdk::{contract, contractimpl, contracttype, Env, Address, Symbol};

#[derive(Clone)]
#[contracttype]
pub struct Escrow {
    pub buyer: Address,
    pub seller: Address,
    pub amount: i128,
    pub released: bool,
}

#[contracttype]
pub enum DataKey {
    Escrow(u64),
    EscrowCount,
}

#[contract]
pub struct EscrowContract;

#[contractimpl]
impl EscrowContract {

    // Create a new escrow agreement
    pub fn create_escrow(
        env: Env,
        buyer: Address,
        seller: Address,
        amount: i128,
    ) -> u64 {
        buyer.require_auth();

        let mut count: u64 = env.storage().instance().get(&DataKey::EscrowCount).unwrap_or(0);
        count += 1;

        let escrow = Escrow {
            buyer,
            seller,
            amount,
            released: false,
        };

        env.storage().instance().set(&DataKey::Escrow(count), &escrow);
        env.storage().instance().set(&DataKey::EscrowCount, &count);

        count
    }

    // Release funds to seller
    pub fn release(env: Env, escrow_id: u64) {
        let mut escrow: Escrow = env
            .storage()
            .instance()
            .get(&DataKey::Escrow(escrow_id))
            .unwrap();

        escrow.buyer.require_auth();

        if escrow.released {
            panic!("Already released");
        }

        escrow.released = true;

        env.storage().instance().set(&DataKey::Escrow(escrow_id), &escrow);
    }

    // Refund buyer
    pub fn refund(env: Env, escrow_id: u64) {
        let mut escrow: Escrow = env
            .storage()
            .instance()
            .get(&DataKey::Escrow(escrow_id))
            .unwrap();

        escrow.seller.require_auth();

        if escrow.released {
            panic!("Already released");
        }

        escrow.released = true;

        env.storage().instance().set(&DataKey::Escrow(escrow_id), &escrow);
    }

    // Get escrow details
    pub fn get_escrow(env: Env, escrow_id: u64) -> Escrow {
        env.storage()
            .instance()
            .get(&DataKey::Escrow(escrow_id))
            .unwrap()
    }
}
